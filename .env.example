# MH Pension App - 환경 변수
# 이 파일을 .env로 복사하고 실제 토큰을 입력하세요.

# Notion Internal Integration Token
# https://www.notion.so/my-integrations 에서 "MH Pension App" 통합의 토큰 복사
NOTION_TOKEN=ntn_여기에_재발급된_토큰_붙여넣기

# Notion Database IDs (만형 이's Space 워크스페이스 기준)
NOTION_ACCOUNTS_DB=a0e1d6ea-a31a-4576-8fa2-a9eead17d0af
NOTION_HOLDINGS_DB=fb793b41-72e3-49f7-9184-c1ac3598235f
